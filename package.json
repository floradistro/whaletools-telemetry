{
  "name": "@neowhale/telemetry",
  "version": "1.1.4",
  "description": "Error tracking, analytics, and Web Vitals for WhaleTools stores",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "whale-logo.png"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "whaletools",
    "telemetry",
    "error-tracking",
    "analytics",
    "web-vitals",
    "monitoring"
  ],
  "author": "WhaleTools <dev@whaletools.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neowhale/telemetry.git"
  },
  "homepage": "https://whaletools.dev/docs",
  "bugs": {
    "url": "https://github.com/neowhale/telemetry/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
